let temperatura = 25;
let novaTemperatura = 5;
let opcao = 1;

switch (opcao) {
    case 1:
        temperatura += novaTemperatura;
        console.log("Temperatura aumentada para: " + temperatura + "°C");
        break;  
    case 2:
        temperatura -= novaTemperatura;
        console.log("Temperatura diminuída para: " + temperatura + "°C");
        break;  
    case 3:
        console.log("Temperatura atual: " + temperatura + "°C");
        break;